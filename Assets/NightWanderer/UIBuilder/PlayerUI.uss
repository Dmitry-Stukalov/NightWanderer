    background-image: url("project://database/Assets/NightWanderer/Sprites/UI/Glow/ButtonGlow.png?fileID=21300000&guid=ca4cbd24cefadc249929c6a99bd992bc&type=3#ButtonGlow");
    -unity-background-image-tint-color: rgba(70, 180, 210, 0.59);
