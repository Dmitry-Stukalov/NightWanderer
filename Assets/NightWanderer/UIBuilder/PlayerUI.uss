:root {
    --main-background-color: rgba(70, 180, 210, 0.4);
    --unactive-background-color: rgba(100, 100, 100, 0.4);
    --hover-background-color: rgba(0, 130, 255, 0.4);
    --active-background-color: rgba(255, 255, 255, 0.4);
    --error-background-color: rgba(255, 0, 0, 0.4);
    --main-text-color: rgb(255, 255, 255);
    --unactive-text-color: rgb(200, 200, 200);
    --main-text-align: middle-center;
}

.GlowMainMenuBackground {
    -unity-background-scale-mode: stretch-to-fill;
    overflow: hidden;
    flex-grow: 0;
    width: 60%;
    align-self: center;
    height: 80%;
    position: absolute;
    bottom: 0%;
    border-top-left-radius: 50px;
    border-top-right-radius: 50px;
    border-top-width: 3px;
    border-right-width: 3px;
    border-bottom-width: 3px;
    border-left-width: 3px;
    justify-content: center;
    -unity-font-definition: url("project://database/Assets/TextMesh%20Pro/Examples%20&%20Extras/SSFBreakthrough-Bold%20SDF.asset?fileID=11400000&guid=784d4999e8270b44bb87566d98892275&type=2#SSFBreakthrough-Bold SDF");
    background-image: url("project://database/Assets/NightWanderer/Sprites/UI/Glow/MainMenuPanelGlow.png?fileID=21300000&guid=034e5467323edad47994a8fae40f5512&type=3#MainMenuPanelGlow");
    display: flex;
    -unity-background-image-tint-color: rgba(70, 180, 210, 0.49);
}

