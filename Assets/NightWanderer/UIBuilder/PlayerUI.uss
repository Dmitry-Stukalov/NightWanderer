.Button {
    background-color: var(--main-background-color);
    border-color: rgb(255, 255, 255);
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
    transition-duration: 0.15s;
}

.Button:hover {
    background-color: var(--hover-background-color);
    border-color: rgb(255, 255, 255);
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-width: 3px;
    border-right-width: 3px;
    scale: 1.07;
    transition-duration: 0.15s;
}

.Button:active {
    background-color: var(--hover-background-color);
    border-color: rgb(255, 255, 255);
    border-top-width: 3px;
    border-bottom-width: 3px;
    border-left-width: 3px;
    border-right-width: 3px;
    scale: 0.9;
    transition-duration: 0.1s;
}

.Button-base {
    background-color: rgba(0, 0, 0, 0);
    border-color: rgb(255, 255, 255);
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
    transition-duration: 0.15s;
}

.Button-base:hover {
    background-color: var(--hover-background-color);
    border-color: rgb(255, 255, 255);
    transition-duration: 0.15s;
}

.Button-base:active {
    background-color: var(--active-background-color);
    border-color: rgb(255, 255, 255);
    transition-duration: 0.1s;
}

.MainBackground {
    background-color: var(--main-background-color);
}

.ErrorBackground {
    background-color: var(--error-background-color);
}

.UnactiveBackground {
    background-color: var(--unactive-background-color);
}

.Button {
    background-color: var(--main-background-color);
    border-color: rgb(255, 255, 255);
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
    transition-duration: 0.15s;
}

.StandartLabel {
    color: var(--main-text-color);
    -unity-text-align: var(--main-text-align);
    font-size: 22px;
}

.StandartUnactiveLabel {
    color: var(--unactive-text-color);
    -unity-text-align: var(--main-text-align);
    font-size: 22px;
}

.SmallUnactiveLabel {
    color: var(--unactive-text-color);
    -unity-text-align: var(--main-text-align);
    font-size: 14px;
}

.SmallLabel {
    color: var(--main-text-color);
    -unity-text-align: var(--main-text-align);
    font-size: 14px;
}

.MainFont {
    -unity-font-definition: initial;
}

.RoundingBorderBig {
    border-radius: 30px;
}

.RoundingBorder {
    border-radius: 20px;
}

.RoundingBorderSmall {
    border-radius: 10px;
}

.BorderAll {
    border-color: rgb(255, 255, 255);
    border-top-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-right-width: 1px;
}

.BorderTop {
    border-color: rgb(255, 255, 255);
    border-top-width: 1px;
}

.BorderBottom {
    border-color: rgb(255, 255, 255);
    border-bottom-width: 1px;
}

.RoundingBorder {
    border-radius: 20px;
}

.BorderLeft {
    border-color: rgb(255, 255, 255);
    border-left-width: 1px;
}

.BorderRight {
    border-color: rgb(255, 255, 255);
    border-right-width: 1px;
}

.BorderCell {
    border-radius: 5px;
    border-color: rgb(255, 255, 255);
    border-width: 1px;
}

.BorderCellWide {
    border-radius: 5px;
    border-color: rgb(255, 255, 255);
    border-width: 2px;
}

