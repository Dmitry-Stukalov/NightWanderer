                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:Label text="Прочее" name="GameTitle" class="StandartLabel BorderTop BorderBottom" style="-unity-text-align: middle-center; margin-bottom: 2%; margin-top: 2%;" />
                <ui:VisualElement name="ResourcePanel" style="flex-grow: 0; height: auto; width: 100%; flex-shrink: 0; align-self: center; flex-direction: row; justify-content: space-between; margin-bottom: 2%;">
                    <ui:Label text="Песок" name="ResourceTitle" class="StandartLabel" style="width: 50%;" />
                    <ui:VisualElement name="ResourceEffectBackground" style="flex-grow: 0; width: 50%;">
                        <ui:Label text="Восстановление всего" name="ResourceEffect" enable-rich-text="false" class="StandartLabel" style="width: 100%; align-self: center;" />
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="ResourcePanel" style="flex-grow: 0; height: auto; width: 100%; flex-shrink: 0; align-self: center; flex-direction: row; justify-content: space-between; margin-bottom: 2%;">
                    <ui:Label text="Титан" name="ResourceTitle" class="StandartLabel" style="width: 50%;" />
                    <ui:VisualElement name="ResourceEffectBackground" style="flex-grow: 0; width: 50%;">
                        <ui:Label text="Восстановление здоровья и защиты" name="ResourceEffect" enable-rich-text="false" class="StandartLabel" style="width: 100%; align-self: center;" />
