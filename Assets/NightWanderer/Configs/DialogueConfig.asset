    <Phrase>k__BackingField:
    - "*\u041A\u043E\u043C\u043F\u043B\u0435\u043A\u0441 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
      \u043C\u0435\u0440\u0442\u0432\u044B\u043C...*"
    - "*\u042F \u043E\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B \u0435\u0433\u043E
      \u0432\u0435\u0441\u044C \u0434\u0435\u043D\u044C, \u0437\u0434\u0435\u0441\u044C
      \u043D\u0438 \u0435\u0434\u0438\u043D\u043E\u0439 \u0434\u0443\u0448\u0438.
      \u0422\u0430\u043A\u043E\u0433\u043E \u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u043E
      \u0431\u044B\u0442\u044C.*"
    - "-\u0415\u0433\u043E\u0440, \u043E\u0442\u0432\u0435\u0442\u044C."
    - "-\u0421\u043B\u044B\u0448\u0443 \u0442\u0435\u0431\u044F. \u041A\u0430\u043A
      \u0432\u0441\u0435 \u043F\u0440\u043E\u0448\u043B\u043E?"
    - "-\u0411\u0430\u0437\u0430 \u043F\u0443\u0441\u0442\u0430, \u0437\u0434\u0435\u0441\u044C
      \u043D\u0438\u043A\u043E\u0433\u043E."
    - "-\u0410 \u043A\u0442\u043E \u0432\u044B\u0434\u0430\u043B \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
      \u043D\u0430 \u0441\u0442\u044B\u043A\u043E\u0432\u043A\u0443?"
    - "-\u0411\u0435\u0437 \u043F\u043E\u043D\u044F\u0442\u0438\u044F, \u043E\u043D\u043E
      \u0443 \u043C\u0435\u043D\u044F \u0443\u0436\u0435 \u0431\u044B\u043B\u043E."
    - "-\u041D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C..."
    - "-\u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0442\u0441\u0435\u043A\u0438
      \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043D\u044B,
      \u0447\u0442\u043E\u0431\u044B \u0432\u0441\u043A\u0440\u044B\u0442\u044C \u0438\u0445
      \u043D\u0443\u0436\u043D\u043E \u0432\u0440\u0435\u043C\u044F. \u0414\u0430\u043D\u043D\u044B\u0445
      \u043E \u0434\u0440\u0443\u0433\u0438\u0445 \u0431\u0430\u0437\u0430\u0445
      \u043F\u043E\u043A\u0430 \u0447\u0442\u043E \u043D\u0435\u0442, \u043D\u0430\u0434\u0435\u044E\u0441\u044C
      \u043D\u0430\u0439\u0442\u0438 \u0438\u0445 \u0442\u0430\u043C."
    - "-\u0422\u0430\u043A\u0438\u0435 \u043D\u043E\u0432\u043E\u0441\u0442\u0438
      \u043C\u0435\u043D\u044F \u0432\u043E\u043E\u0431\u0449\u0435 \u043D\u0435
      \u0440\u0430\u0434\u0443\u044E\u0442..."
    - "-\u0422\u0430\u043A \u0443\u0436 \u0438 \u0431\u044B\u0442\u044C, \u043C\u044B
      \u0441\u0442\u0430\u0432\u0438\u043C \u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u043A\u0443."
    - "-\u041A\u0430\u043A \u0442\u044B \u0437\u043D\u0430\u0435\u0448\u044C, \u043F\u043E\u043C\u043E\u0449\u0438
      \u043E\u0442 \u043D\u0430\u0441 \u043D\u0438\u043A\u0430\u043A\u043E\u0439,
      \u0442\u0430\u043A \u0447\u0442\u043E \u0443 \u0442\u0435\u0431\u044F 90 \u0434\u043D\u0435\u0439
      \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0439\u0442\u0438 \u0434\u0430\u043D\u043D\u044B\u0435
      \u0438 \u043A\u0430\u043A\u0438\u043C-\u0442\u043E \u0447\u0443\u0434\u043E\u043C
      \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u043D\u0430\u0437\u0430\u0434.
      \u0415\u0441\u043B\u0438 \u043D\u0435 \u0443\u0441\u043F\u0435\u0435\u0448\u044C,
      \u043C\u044B \u0443\u043B\u0435\u0442\u0438\u043C \u0431\u0435\u0437 \u0442\u0435\u0431\u044F."
    - "-\u0414\u0430, \u044F \u043F\u043E\u043C\u043D\u044E."
    - "-\u041A\u043E\u0440\u0430\u0431\u043B\u044C \u043F\u043E\u0447\u0438\u043D\u0438\u0442\u044C
      \u0443\u0434\u0430\u0441\u0442\u0441\u044F?"
    - "-\u041D\u0430\u0434\u0435\u044E\u0441\u044C. \u041D\u0430 \u0431\u0430\u0437\u0435
      \u0435\u0441\u0442\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432.
      \u041E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u0438\u0434\u0435\u0442\u0441\u044F
      \u0434\u043E\u0431\u044B\u0432\u0430\u0442\u044C \u0441\u0430\u043C\u043E\u043C\u0443."
    - "-\u041E\u0442\u043B\u0438\u0447\u043D\u043E, \u0442\u043E\u0433\u0434\u0430
      \u0437\u0430\u0439\u043C\u0438\u0441\u044C \u044D\u0442\u0438\u043C \u0432
      \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C."
    - "-\u0412\u0441\u0435, \u043D\u0435 \u0442\u0435\u0440\u044F\u0439 \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
      \u043D\u043E\u0447\u044C \u043D\u0435 \u0431\u0443\u0434\u0435\u0442 \u0434\u043B\u0438\u0442\u0441\u044F
      \u0432\u0435\u0447\u043D\u043E, \u0430 \u0434\u043D\u0435\u043C \u0442\u0435\u0431\u0435
      \u043F\u043E\u043A\u0430 \u0447\u0442\u043E \u043B\u0443\u0447\u0448\u0435
      \u043D\u0435 \u0432\u044B\u0441\u043E\u0432\u044B\u0432\u0430\u0442\u044C\u0441\u044F."
    - "-\u0422\u0432\u043E\u044F \u043F\u0440\u0430\u0432\u0434\u0430... \u041E\u0442\u0431\u043E\u0439."
