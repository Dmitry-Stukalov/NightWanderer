    - "\u041A\u043E\u0440\u0430\u0431\u043B\u044C"
    - "\u041A\u043E\u0440\u0430\u0431\u043B\u044C"
    <Phrase>k__BackingField:
    - "-\u0412\u0441\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0438\u0441\u043F\u0440\u0430\u0432\u043D\u044B."
    - "-\u041D\u0430\u0447\u0438\u043D\u0430\u044E \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0443
      \u043A \u0437\u0430\u043F\u0443\u0441\u043A\u0443."
    - "-\u041F\u0440\u0438\u0435\u043C. \u0421\u0432\u044F\u0437\u044C \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442?"
    - "-\u0414\u0430, \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043E\u0442\u043B\u0438\u0447\u043D\u043E."
    - "-\u0414\u0430\u0432\u0430\u0439 \u0435\u0449\u0435 \u0440\u0430\u0437 \u043F\u0440\u043E\u0439\u0434\u0435\u043C\u0441\u044F
      \u043F\u043E \u0437\u0430\u0434\u0430\u0447\u0430\u043C."
    - "-\u0414\u043E\u0431\u0438\u0440\u0430\u044E\u0441\u044C \u0434\u043E \u0432\u043D\u0435\u0448\u043D\u0435\u0439
      \u0441\u0435\u0432\u0435\u0440\u043D\u043E\u0439 \u0431\u0430\u0437\u044B.
      \u0414\u0435\u043B\u0430\u044E \u0432\u0438\u0434, \u0447\u0442\u043E \u043F\u0440\u0438\u0431\u044B\u043B
      \u043E\u0442 \u043B\u0438\u0446\u0430 \u043A\u043E\u0440\u043F\u043E\u0440\u0430\u0446\u0438\u0438.
      \u041F\u043E\u043B\u0443\u0447\u0430\u044E \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
      \u043D\u0430 \u0441\u0442\u044B\u043A\u043E\u0432\u043A\u0443. \u0412 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
      \u0442\u0440\u0435\u0445 \u0434\u043D\u0435\u0439 \u043F\u043E\u043B\u0443\u0447\u0430\u044E
      \u0434\u0430\u043D\u043D\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
      \u0438 \u043F\u043E\u043A\u0438\u0434\u0430\u044E \u043F\u043B\u0430\u043D\u0435\u0442\u0443."
    - "-\u041A\u0430\u043A\u0438\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
      \u0435\u0441\u043B\u0438 \u043D\u0435 \u0432\u0441\u0435 \u0434\u0430\u043D\u043D\u044B\u0435
      \u0433\u043E\u0442\u043E\u0432\u044B?"
    - "-\u0412\u044B \u0431\u043B\u043E\u043A\u0438\u0440\u0443\u0435\u0442\u0435
      \u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439 \u043F\u0440\u043E\u0445\u043E\u0434,
      \u044F \u043E\u0441\u0442\u0430\u044E\u0441\u044C \u043D\u0430 \u0431\u0430\u0437\u0435
      \u0441\u0442\u043E\u043B\u044C\u043A\u043E, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
      \u043F\u043E\u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F, \u043D\u043E
      \u043D\u0435 \u0434\u043E\u043B\u044C\u0448\u0435 90 \u0434\u043D\u0435\u0439.
      \u0422\u0430\u043A\u0436\u0435 \u0437\u0430\u0431\u0438\u0440\u0430\u044E \u0434\u0430\u043D\u043D\u044B\u0435
      \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0438
      \u0443\u043B\u0435\u0442\u0430\u044E."
    - "-\u041E\u0442\u043B\u0438\u0447\u043D\u043E. \u041F\u043E\u0441\u043B\u0435
      \u043F\u0440\u0438\u0437\u0435\u043C\u043B\u0435\u043D\u0438\u044F \u0441\u0432\u044F\u0437\u044C
      \u0440\u0430\u0437 \u0432 \u0434\u0435\u043D\u044C \u0440\u043E\u0432\u043D\u043E
      \u0432 \u043F\u043E\u043B\u043D\u043E\u0447\u044C."
    - "-\u0414\u0430, \u044F \u043F\u043E\u043C\u043D\u044E."
    - "-\u042D\u0442\u043E \u0445\u043E\u0440\u043E\u0448\u043E. 5 \u0441\u0435\u043A\u0443\u043D\u0434\u043D\u0430\u044F
      \u0433\u043E\u0442\u043E\u0432\u043D\u043E\u0441\u0442\u044C."
    - "-\u0417\u0430\u043F\u0443\u0441\u043A \u0447\u0435\u0440\u0435\u0437 5..."
    - 4...
    - 3...
    - 2...
    - 1...
    - "\u0417\u0430\u043F\u0443\u0441\u043A!"
